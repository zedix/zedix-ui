{
  "name": "@zedix/zedix-ui",
  "version": "0.9.9",
  "description": "A library of essential web components (lit-based), serving as a foundation for web apps or design systems.",
  "license": "MIT",
  "author": "@zedix",
  "repository": {
    "type": "git",
    "url": "https://github.com/zedix/zedix-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/components/*": "./dist/components/*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "analyze": "cem analyze --litelement",
    "build": "vite build",
    "build:storybook": "storybook build --output-dir='.storybook/build'",
    "gen:react": "lit labs gen --framework=react",
    "gen:vue": "lit labs gen --framework=vue",
    "start": "tsc && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"wds\"",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublish_": "tsc && npm run analyze -- --exclude dist",
    "publish": "yarn npm publish",
    "release": "yarn changelogen --release",
    "test": "web-test-runner --group default",
    "test:component": "web-test-runner -- --watch --group",
    "test:watch": "web-test-runner --watch --group default",
    "storybook": "storybook dev -p 6006",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit-labs/cli": "^0.6.6",
    "@lit-labs/gen-wrapper-react": "^0.3.5",
    "@lit-labs/gen-wrapper-vue": "^0.4.2",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-links": "^10.2.13",
    "@storybook/web-components": "^10.2.13",
    "@storybook/web-components-vite": "^10.2.13",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.0",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "changelogen": "^0.6.2",
    "concurrently": "^9.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "sinon": "^21.0.1",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.12.0"
}
